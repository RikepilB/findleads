# Dependencies
node_modules/
.venv/
__pycache__/

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo

# Environment & local overrides (the repo is the prompt — but secrets are not)
.env
.env.*
!.env.example
CLAUDE.local.md
.claude/settings.local.json

# Logs & caches
*.log
coverage/
.cache/
.pytest_cache/
